# Server Configuration
PORT=3000
NODE_ENV=development

# CORS - Allowed origins (comma-separated for multiple origins)
# For production, replace with your actual domain
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://yourdomain.com

# JWT Secret - CHANGE THIS to a random string in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin Credentials
ADMIN_USERNAME=Admin

# Admin Password Hash - NEVER store plain text password!
# Generate by running: node hash-password.js
# Password will be: 420admin (or whatever you choose)
ADMIN_PASSWORD_HASH=$2a$10$example.hash.will.be.generated.by.script

# Database (SQLite - no config needed, but you can specify path if needed)
# DB_PATH=./messages.db
