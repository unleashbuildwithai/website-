# ─── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── PostgreSQL (replaces SQLite) ────────────────────────────
# Get this from Render Dashboard > PostgreSQL > Connection Details
# OR from Supabase > Settings > Database > Connection String
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Admin Auth ───────────────────────────────────────────────
ADMIN_USERNAME=Admin
# Generate with: node hash-password.js   then paste the hash here
ADMIN_PASSWORD_HASH=$2b$10$...

# ─── JWT ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your Cloudflare Pages URL)
ALLOWED_ORIGINS=https://geniusunleashed.pages.dev,https://yourdomain.com

# ─── GitHub Archive (Phase 2) ─────────────────────────────────
# Create a Personal Access Token at:
#   GitHub → Settings → Developer settings → Personal access tokens → Tokens (classic)
#   Scope needed: repo (Full control of private repositories)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your GitHub username or org name
GITHUB_OWNER=unleashbuildwithai

# Your repository name (this repo)
GITHUB_REPO=website-

# Branch to commit archives to (usually main)
GITHUB_BRANCH=main
